{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Pulseboard",
  "version": "0.1.0",
  "identifier": "com.opencraft.pulseboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Pulseboard",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["pulseboard"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
