{
  "name": "timely",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite",
    "generate:holidays": "node scripts/generate-holidays-data.cjs",
    "tauri:dev": "tauri dev",
    "tauri:dev:fresh": "rm -rf \"$HOME/Library/Application Support/com.opencraft.timely/timely.sqlite3\" && tauri dev",
    "build": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "oxlint src/",
    "lint:rs": "cd src-tauri && cargo clippy -- -D warnings",
    "fmt": "oxfmt --write src/ && cd src-tauri && cargo fmt",
    "fmt:check": "oxfmt --check src/ && cd src-tauri && cargo fmt --check",
    "fmt:rs": "cd src-tauri && cargo fmt",
    "doctor": "npx -y react-doctor@latest . -y"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.166.2",
    "@tauri-apps/api": "^2.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "driver.js": "^1.4.0",
    "lucide-react": "^0.511.0",
    "motion": "^12.35.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "date-holidays": "^3.26.9",
    "jsdom": "^26.1.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.3",
    "vite": "^6.2.0",
    "vitest": "^3.2.4"
  }
}
