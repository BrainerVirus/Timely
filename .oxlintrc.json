{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "overrides": [
    {
      "files": ["src/shared/**/*.ts", "src/shared/**/*.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["@/features/*"],
                "message": "shared/ must not import from features/; use shared components, hooks, utils instead."
              },
              {
                "group": ["@/core/layout/*"],
                "message": "shared/ must not import from layout; keep shared layer dependency-free from app shell."
              }
            ]
          }
        ]
      }
    }
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "off",
    "perf": "warn",
    "style": "off",
    "restriction": "off"
  },
  "plugins": ["typescript", "react", "import", "jsx-a11y", "unicorn"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@/**/index", "@/**/index.*"],
            "message": "Use direct file imports instead of barrel imports."
          },
          {
            "group": ["@/**/public", "@/**/public/*"],
            "message": "Do not import from public API folders under src/."
          }
        ]
      }
    ],
    "unicorn/no-useless-spread": "off",
    "unicorn/no-array-sort": "off",
    "unicorn/consistent-function-scoping": "off",
    "unicorn/prefer-add-event-listener": "off",
    "unicorn/filename-case": [
      "warn",
      {
        "cases": {
          "kebabCase": true,
          "pascalCase": true
        }
      }
    ],
    "no-unused-vars": "error",
    "no-console": "warn",
    "import/first": "error",
    "import/no-duplicates": "error",
    "import/no-unassigned-import": "off",
    "react/no-direct-mutation-state": "error",
    "react/jsx-no-target-blank": "error",
    "react/no-children-prop": "error",
    "react/react-in-jsx-scope": "off",
    "react/jsx-key": "error",
    "react/no-unknown-property": "off",
    "typescript/no-non-null-assertion": "off",
    "jsx-a11y/label-has-associated-control": "off"
  },
  "ignorePatterns": [
    "dist",
    "target",
    "node_modules",
    "src-tauri/target",
    "*.config.*"
  ],
  "settings": {
    "react": {
      "linkComponents": [{ "name": "Link", "attribute": "to" }]
    },
    "jsx-a11y": {
      "components": {
        "Button": "button"
      }
    }
  }
}
